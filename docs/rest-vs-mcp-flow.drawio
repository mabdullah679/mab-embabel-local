        <mxCell id="subtitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontColor=#5f7385;" value="The browser still uses REST for direct editing; the orchestrator now uses strict planning plus deterministic execution instead of regex-driven CRUD." vertex="1">
