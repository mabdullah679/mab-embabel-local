        <mxCell id="browser" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#ffffff;strokeColor=#9dbdd1;fontSize=17;align=left;spacing=20;" value="&lt;b&gt;Frontend UI&lt;/b&gt;&lt;br&gt;calendar editor&lt;br&gt;email draft editor&lt;br&gt;contact manager" vertex="1">
